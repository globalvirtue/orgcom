# ─── Base Stage ───
FROM node:20-alpine AS base
WORKDIR /app
COPY backend/package.json backend/package-lock.json* ./
RUN npm install
COPY backend/ .

# ─── Development Stage ───
FROM base AS dev
WORKDIR /app
RUN mkdir -p uploads/audio
EXPOSE 3001
CMD ["npx", "tsx", "watch", "src/app.ts"]

# ─── Production Stage ───
FROM base AS prod
WORKDIR /app
RUN mkdir -p uploads/audio
EXPOSE 3001
CMD ["npx", "tsx", "src/app.ts"]
